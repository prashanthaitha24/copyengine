# Copy to .env.local for development. Never commit .env or .env.local.

# Postgres (Neon connection string)
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Envelope encryption master key for stored Tradovate creds.
# Generate with: openssl rand -base64 32
VAULT_MASTER_KEY=

# Tradovate OAuth app credentials (from https://api.tradovate.com)
TRADOVATE_CLIENT_ID=
TRADOVATE_CLIENT_SECRET=
TRADOVATE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/tradovate/callback

# Tradovate environment: "demo" or "live"
TRADOVATE_ENV=demo

# Engine HTTP port (web → engine control + SSE)
ENGINE_PORT=4000
ENGINE_BASE_URL=http://localhost:4000

# Web auth (Resend magic links)
RESEND_API_KEY=
AUTH_SECRET=
